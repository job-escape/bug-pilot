# ─── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, Railway, or local)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ─── Slack ───────────────────────────────────────────────────────────────────

# Bot token (xoxb-...) from your Slack app OAuth page
SLACK_BOT_TOKEN=xoxb-...

# Signing secret from your Slack app Basic Information page
SLACK_SIGNING_SECRET=...

# ─── GitHub ──────────────────────────────────────────────────────────────────

# Personal access token with repo read + write access
GITHUB_TOKEN=ghp_...

# Secret for GitHub webhook signature verification (any random string)
GITHUB_WEBHOOK_SECRET=your-random-secret

# ─── Anthropic ───────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ──────────────────────────────────────────────────────────────────

# Bot HTTP port (default: 3001)
PORT=3001

# URL where the dashboard is accessible (used for links in DMs)
# Local dev: http://localhost:3000
# Production: https://your-dashboard.vercel.app
DASHBOARD_URL=http://localhost:3000

# ─── Configured via Dashboard UI ─────────────────────────────────────────────
# Set at /settings in the dashboard — no need to add here:
#   TRIGGER_EMOJI      - emoji that triggers parsing (default: robot_face)
#   ALLOWED_CHANNELS   - Slack channel IDs the bot listens to
#   ALLOWED_USER_ID    - Slack user ID who can trigger the bot
#   FIX_MODEL          - Claude model for fixing (default: claude-sonnet-4-6)
#   PARSER_MODEL       - Claude model for parsing (default: claude-haiku-4-5)
